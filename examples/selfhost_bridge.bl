; selfhost_bridge.bl ‚Äî the proposer/disposer bridge (S2, v0.1 roadmap arc S).
;
; The Blight-written elaborator (spore_elab.bl, `belaborate`) PROPOSES a typing for each object-
; language term in the corpus below; spore_print.bl renders that verdict as ordinary Blight surface
; text ‚Äî `ACCEPT (the ‚ü¶a‚üß ‚ü¶s‚üß)` for a term it types at `a`, or `REJECT`. The accompanying Rust test
; (`crates/blight-repl/src/main.rs`, `example_selfhost_bridge‚Ä¶`) then has the *real* kernel
; independently re-check each `ACCEPT` payload (DISPOSE): a well-typed embedding must check, and a
; forged/ill-typed one must be rejected. So the front end's verdict is verified against the trusted
; kernel, never trusted ‚Äî the first time the kernel re-checks a *term* the Blight front end produced,
; not just a boolean.
;
;   cargo run -p blight-repl --features llvm -- build examples/selfhost_bridge.bl -o selfhost_bridge
;   ./selfhost_bridge
;   # BRIDGE 0 ACCEPT (the (Pi ((v Base)) Base) (lam (v0) v0))
;   # BRIDGE 1 ACCEPT (the (Pi ((v (Pi ((v Base)) Base))) (Pi ((v Base)) Base)) (lam (v0) v0))
;   # ‚Ä¶
;   # BRIDGE 4 REJECT
;   # ‚Ä¶
;
; The object language is the modelled toy STLC: `su-var i` (de Bruijn), `su-lam dom body`,
; `su-app fn arg`. Pure except for the `Console` prints; effects re-checked at the type level.

(load "spore_print.bl")  ; bridge-line, and transitively belaborate + BSurf/BTy
(load "std/io.bl")  ; Console (put-str)

(define nl String "\n")

; ‚îÄ‚îÄ The corpus: object-language terms, well-typed and ill-typed ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
; 0. Œªx:Base. x                         : Base ‚Üí Base                       (identity ‚Äî ACCEPT)
(define c0 BSurf (su-lam Base (su-var Zero)))
; 1. Œªx:(Base‚ÜíBase). x                  : (Base‚ÜíBase) ‚Üí (Base‚ÜíBase)         (higher-order id ‚Äî ACCEPT)
(define c1 BSurf (su-lam (Arr Base Base) (su-var Zero)))
; 2. Œªf:(Base‚ÜíBase). Œªx:Base. f x       : (Base‚ÜíBase) ‚Üí Base ‚Üí Base         (application ‚Äî ACCEPT)
(define c2 BSurf (su-lam (Arr Base Base) (su-lam Base (su-app (su-var (Succ Zero)) (su-var Zero)))))
; 3. Œªx:Base. Œªy:Base. x                : Base ‚Üí Base ‚Üí Base                (const / shadowing ‚Äî ACCEPT)
(define c3 BSurf (su-lam Base (su-lam Base (su-var (Succ Zero)))))
; 4. Œªx:Base. (x x)                     : ‚Äî  (a Base applied as a function) (self-app ‚Äî REJECT)
(define c4 BSurf (su-lam Base (su-app (su-var Zero) (su-var Zero))))
; 5. #0 in the empty context           : ‚Äî  (an unbound variable)          (out of scope ‚Äî REJECT)
(define c5 BSurf (su-var Zero))
; 6. Œªf:(Base‚ÜíBase). Œªx:Base. Œªy:Base. ((f x) y)  : ‚Äî  (f x : Base applied to y) (domain mismatch ‚Äî REJECT)
(define c6 BSurf
  (su-lam (Arr Base Base)
    (su-lam Base
      (su-lam Base (su-app (su-app (su-var (Succ (Succ Zero))) (su-var (Succ Zero))) (su-var Zero))))))
; ‚îÄ‚îÄ S4a: the Nat base type (‚ü¶NatT‚üß = the host `Nat`) and its zero/succ introducers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
; 7. Œªx:Nat. x                          : Nat ‚Üí Nat                         (identity on Nat ‚Äî ACCEPT)
(define c7 BSurf (su-lam NatT (su-var Zero)))
; 8. (succ (succ zero))                 : Nat                               (the literal 2 ‚Äî ACCEPT)
(define c8 BSurf (su-succ (su-succ su-zero)))
; 9. Œªx:Nat. (succ x)                   : Nat ‚Üí Nat                         (successor fn ‚Äî ACCEPT)
(define c9 BSurf (su-lam NatT (su-succ (su-var Zero))))
; 10. (succ (Œªx:Base. x))              : ‚Äî  (successor of a function)       (ill-typed ‚Äî REJECT)
(define c10 BSurf (su-succ (su-lam Base (su-var Zero))))

; Print one `BRIDGE <idx> <verdict>` line, then a newline, sequencing under `Console`.
(deftotal emit (Pi ((idx Nat) (s BSurf)) (! Console Unit))
  (lam (idx s) (put-str (string-append (bridge-line idx s) nl))))

(define main (! Console Unit)
  (let ((u0 (emit 0 c0)))
    (let ((u1 (emit 1 c1)))
      (let ((u2 (emit 2 c2)))
        (let ((u3 (emit 3 c3)))
          (let ((u4 (emit 4 c4)))
            (let ((u5 (emit 5 c5)))
              (let ((u6 (emit 6 c6)))
                (let ((u7 (emit 7 c7)))
                  (let ((u8 (emit 8 c8)))
                    (let ((u9 (emit 9 c9))) (emit 10 c10))))))))))))
