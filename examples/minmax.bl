; minmax.bl тАФ `min`/`max` on naturals from std/nat.
;
; `plus (min 2 5) (max 2 5) = 2 + 5 = 7` (in general `min a b + max a b = a + b`). Buildable:
;
;   cargo run -p blight-repl --features llvm -- build examples/minmax.bl -o minmax
;   ./minmax      # prints 7

(load "std/nat.bl")

(define a Nat (Succ (Succ Zero)))  ; 2
(define b Nat (Succ (Succ (Succ (Succ (Succ Zero))))))  ; 5

(define main Nat (plus (min a b) (max a b)))
