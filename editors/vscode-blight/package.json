{
  "name": "blight",
  "displayName": "Blight",
  "description": "Syntax highlighting and Language Server support (diagnostics, hover, go-to-definition, completion, formatting, local rename) for the Blight (.bl) language.",
  "version": "0.3.0",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:blight"
  ],
  "contributes": {
    "languages": [
      {
        "id": "blight",
        "aliases": [
          "Blight",
          "blight"
        ],
        "extensions": [
          ".bl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "blight",
        "scopeName": "source.blight",
        "path": "./syntaxes/blight.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Blight",
      "properties": {
        "blight.serverPath": {
          "type": "string",
          "default": "blight-lsp",
          "description": "Path to the blight-lsp executable (built via `cargo build -p blight-lsp`). Defaults to looking it up on PATH."
        },
        "blight.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP communication between the extension and blight-lsp, shown in the 'Blight Language Server' output channel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.4.0"
  }
}
